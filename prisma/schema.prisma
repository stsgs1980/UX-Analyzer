generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Analysis {
  id        String   @id @default(cuid())
  urls      String
  result    String?
  status    String   @default("pending")
  error     String?
  sourceType String   @default("url")
  imageUrl  String?
  designMd  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}